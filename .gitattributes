# Enforce LF for files that break with CRLF inside Linux containers / shells.
# (Hard-won lesson: CRLF in *.sh silently kills container entrypoints.)
* text=auto eol=lf
*.sh   text eol=lf
*.env  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.py   text eol=lf
# Windows-only tooling keeps CRLF
*.ps1  text eol=crlf
