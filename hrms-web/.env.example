# Copy to .env.local. NOVU_API_KEY is the environment Secret Key from the Novu dashboard
# (Developer > API Keys). All server-only - never exposed to the browser.
NOVU_API_URL=http://localhost:3010
NOVU_WS_URL=http://localhost:3011
NOVU_API_KEY=
NOVU_APPLICATION_IDENTIFIER=

# Web Push (VAPID) - real browser push, NO Firebase. Generate a keypair with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@hrms.local
