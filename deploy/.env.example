# ─────────────────────────────────────────────────────────────────────────────
# Novu self-hosted — env template for the HRMS notification POC.
# Copy to `.env` and fill the secrets (the real .env is gitignored).
# Generate secrets with:  ../scripts/gen-secrets.ps1   (or see the commands below)
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets (REQUIRED — never commit real values) ──
# openssl rand -hex 32
JWT_SECRET=
# openssl rand -hex 32
NOVU_SECRET_KEY=
# EXACTLY 32 chars — openssl rand -hex 16
STORE_ENCRYPTION_KEY=
SUBSCRIBER_WIDGET_JWT_EXPIRATION_TIME=15d

# ── General ──
NODE_ENV=local
IS_SELF_HOSTED=true
HOST_NAME=http://localhost

# ── Ports (tailored to avoid HRMS collisions — HRMS frontend runs on :3000) ──
API_PORT=3010
WS_PORT=3011
WORKER_PORT=3004
REDIS_PORT=6379
REDIS_CACHE_SERVICE_PORT=6379

# ── MongoDB ──
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=
MONGO_URL=mongodb://${MONGO_INITDB_ROOT_USERNAME}:${MONGO_INITDB_ROOT_PASSWORD}@novu-mongodb:27017/novu-db?authSource=admin
MONGO_MIN_POOL_SIZE=5
MONGO_MAX_POOL_SIZE=10
MONGO_AUTO_CREATE_INDEXES=true

# ── Redis (single instance also used as the cache service) ──
REDIS_HOST=novu-redis
REDIS_PASSWORD=
REDIS_CACHE_SERVICE_HOST=novu-redis
REDIS_SKIP_VERSION_CHECK=false

# ── Root URLs (browser-facing — the dashboard is a client-side Vite app) ──
API_ROOT_URL=${HOST_NAME}:3010
VITE_API_HOSTNAME=${HOST_NAME}:3010
VITE_WEBSOCKET_HOSTNAME=${HOST_NAME}:3011
# CORS origin match for the dashboard (regex; community default allows 4000|4200)
FRONT_BASE_URL=${HOST_NAME}:(4000|4200)

# ── Feature flags ──
IS_API_IDEMPOTENCY_ENABLED=false
IS_API_RATE_LIMITING_ENABLED=false
IS_NEW_MESSAGES_API_RESPONSE_ENABLED=true
IS_V2_ENABLED=true
IS_EMAIL_INLINE_CSS_DISABLED=false
IS_USE_MERGED_DIGEST_ID_ENABLED=false

# ── S3 (unused in community edition — attachments use filesystem storage) ──
S3_LOCAL_STACK=
S3_BUCKET_NAME=novu-local
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ── Analytics (off) ──
SENTRY_DSN=
NEW_RELIC_ENABLED=false
NEW_RELIC_APP_NAME=novu-poc
NEW_RELIC_LICENSE_KEY=

# ── Queue tuning ──
BROADCAST_QUEUE_CHUNK_SIZE=100
MULTICAST_QUEUE_CHUNK_SIZE=100

# ─────────────────────────────────────────────────────────────────────────────
# Bridge / demo config (consumed by bridge/ + demo/, NOT by the Novu containers).
# These are DIFFERENT from the container secrets above.
# ─────────────────────────────────────────────────────────────────────────────
NOTIFY_ENGINE=dual
# The ENVIRONMENT SECRET KEY from Dashboard > Settings > API Keys (starts with sk_...).
# NOT the same as NOVU_SECRET_KEY above. Paste it here after creating the org.
NOVU_API_KEY=
# The public Application Identifier (Dashboard > Settings > API Keys). scripts/seed.ps1 fills this.
NOVU_APPLICATION_IDENTIFIER=
